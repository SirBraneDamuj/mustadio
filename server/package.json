{
  "name": "mustadio-server",
  "version": "1.0.0",
  "description": "Mustadio server - FFT Battleground companion app",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:loader": "tsx watch src/loader.ts",
    "dev:bg": "./scripts/dev-server.sh start",
    "dev:stop": "./scripts/dev-server.sh stop",
    "dev:restart": "./scripts/dev-server.sh restart",
    "dev:status": "./scripts/dev-server.sh status",
    "dev:logs": "./scripts/dev-server.sh logs",
    "loader:bg": "./scripts/dev-server.sh loader start",
    "loader:stop": "./scripts/dev-server.sh loader stop",
    "loader:restart": "./scripts/dev-server.sh loader restart",
    "loader:status": "./scripts/dev-server.sh loader status",
    "loader:logs": "./scripts/dev-server.sh loader logs",
    "start": "node dist/index.js",
    "start:loader": "node dist/loader.js",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.4.1",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.3",
    "hono": "^4.6.12",
    "jsdom": "^24.1.3",
    "pg": "^8.17.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "prisma": "^7.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
